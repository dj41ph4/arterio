#############################################
# Arterio — Environment configuration
# Copy to .env and fill in. NEVER commit .env.
#############################################

# ----- General -----
NODE_ENV=development
# Public base URL of the web app
APP_URL=http://localhost:3000
# Public base URL of the API
API_URL=http://localhost:4000
# Set to true to make the API serve HTTPS directly, using a self-signed cert
# generated fresh at every boot. Only useful if your reverse proxy connects
# to the upstream over HTTPS too — the proxy still presents its own real,
# trusted certificate to end users; this one is never meant to be trusted
# directly.
HTTPS_ENABLED=false
# Default locale + supported locales (comma separated)
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,fr,it,es,de,nl

# ----- PostgreSQL -----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=arterio
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=arterio
# Full URL consumed by Prisma
DATABASE_URL=postgresql://arterio:change-me-in-production@localhost:5432/arterio?schema=public

# ----- Redis (cache, queues, rate-limit, sessions) -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ----- Elasticsearch (full-text + faceted search) -----
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# ----- Object storage (S3 compatible: MinIO / AWS / Wasabi / Synology) -----
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=arterio
S3_SECRET_KEY=change-me-in-production
S3_BUCKET=arterio-media
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:9000/arterio-media

# ----- Auth / security -----
# Generate strong values: `openssl rand -base64 48`
JWT_ACCESS_SECRET=replace-with-strong-random-secret
JWT_REFRESH_SECRET=replace-with-another-strong-random-secret
JWT_ACCESS_TTL=900            # 15 minutes (seconds)
JWT_REFRESH_TTL=2592000       # 30 days (seconds)
# 32-byte key (base64) for AES-256-GCM field/document encryption
DATA_ENCRYPTION_KEY=replace-with-base64-32-byte-key
# Argon2id tuning
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1
# WebAuthn / Passkeys
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Arterio
WEBAUTHN_ORIGIN=http://localhost:3000

# ----- OAuth providers (optional) -----
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=

# ----- Email (notifications) -----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Arterio <no-reply@arterio.app>"

# ----- Notifications (optional integrations) -----
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=

# ----- AI (DISABLED by default — wiring ready for later) -----
# When AI_ENABLED=false the platform runs fully without any AI provider.
AI_ENABLED=false
AI_PROVIDER=anthropic          # anthropic | openai | local | none
# Default to the latest, most capable Claude model when AI is turned on.
AI_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=
AI_VISION_ENABLED=false        # description, style/signature analysis, similar-image search
AI_OCR_ENABLED=false           # OCR text extraction
AI_EMBEDDINGS_MODEL=           # for similar-image / semantic search (e.g. CLIP)

# ----- Artist enrichment fallback sources -----
# Used only when Wikidata has no unambiguous art-world match for an artist name.
# Met Museum + Art Institute of Chicago need no key and are always active.
# These four are free but require registering for a key; left blank, they no-op.
EUROPEANA_API_KEY=     # https://pro.europeana.eu/get-api
RIJKSMUSEUM_API_KEY=   # https://www.rijksmuseum.nl/en/rijksstudio/artists (API tab)
HARVARD_API_KEY=       # https://harvardartmuseums.org/collections/api
SMITHSONIAN_API_KEY=   # https://api.data.gov/signup (Smithsonian Open Access)

# ----- Outbound email (optional) -----
# Self-service "forgot password" only works when this is set; otherwise an
# admin resets a member's password from Settings → Members instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_FROM=Arterio <no-reply@arterio.app>

# ----- Observability -----
LOG_LEVEL=info
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
